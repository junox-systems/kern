<%= form_with(model: commitment) do |form| %>
  <% if commitment.errors.any? %>
    <div style="color: red">
      <h2><%= pluralize(commitment.errors.count, "error") %> prohibited this commitment from being saved:</h2>

      <ul>
        <% commitment.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :user_id, style: "display: block" %>
    <%= form.text_field :user_id %>
  </div>

  <div>
    <%= form.label :category_id, style: "display: block" %>
    <%= form.text_field :category_id %>
  </div>

  <div>
    <%= form.label :title, style: "display: block" %>
    <%= form.text_field :title %>
  </div>

  <div>
    <%= form.label :description, style: "display: block" %>
    <%= form.textarea :description %>
  </div>

  <div>
    <%= form.label :context, style: "display: block" %>
    <%= form.textarea :context %>
  </div>

  <div>
    <%= form.label :capability, style: "display: block" %>
    <%= form.number_field :capability %>
  </div>

  <div>
    <%= form.label :estimate_minutes, style: "display: block" %>
    <%= form.number_field :estimate_minutes %>
  </div>

  <div>
    <%= form.label :due_at, style: "display: block" %>
    <%= form.datetime_field :due_at %>
  </div>

  <div>
    <%= form.label :available_after, style: "display: block" %>
    <%= form.datetime_field :available_after %>
  </div>

  <div>
    <%= form.label :state, style: "display: block" %>
    <%= form.number_field :state %>
  </div>

  <div>
    <%= form.submit %>
  </div>
<% end %>
