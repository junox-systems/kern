<div class="max-w-xl mx-auto mt-10 p-6 bg-base-100 rounded shadow-md">
  <h1 class="text-3xl font-bold mb-6 text-primary">Profile Settings</h1>

  <%= form_with(model: @user, url: profile_path, method: :patch, data: { turbo: false }) do |form| %>
    <% if @user.errors.any? %>
      <div class="text-error p-4 rounded mb-6 bg-error/10">
        <h2 class="font-bold"><%= pluralize(@user.errors.count, "error") %> prohibited this profile from being saved:</h2>
        <ul class="list-disc ml-5 mt-2">
          <% @user.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="mb-4">
      <%= form.label :name, class: "block font-medium mb-1" %>
      <%= form.text_field :name, class: "input input-bordered w-full", required: true %>
    </div>

    <div class="mb-4">
      <%= form.label :email_address, "Email Address", class: "block font-medium mb-1" %>
      <%= form.email_field :email_address, class: "input input-bordered w-full", required: true %>
    </div>

    <div class="mb-4">
      <%= form.label :timezone, "Time Zone", class: "block font-medium mb-1" %>
      <%= form.time_zone_select :timezone, nil, {}, { class: "select select-bordered w-full" } %>
    </div>

    <div class="divider my-6">Change Password (optional)</div>

    <div class="mb-4">
      <%= form.label :password, "New Password", class: "block font-medium mb-1" %>
      <%= form.password_field :password, class: "input input-bordered w-full", placeholder: "Leave blank to keep current" %>
    </div>

    <div class="mb-6">
      <%= form.label :password_confirmation, "Confirm New Password", class: "block font-medium mb-1" %>
      <%= form.password_field :password_confirmation, class: "input input-bordered w-full", placeholder: "Leave blank to keep current" %>
    </div>

    <%= form.submit "Update Profile", class: "btn btn-primary w-full" %>
  <% end %>
</div>
